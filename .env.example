# Civitas runtime configuration (local development baseline)

# PostgreSQL connection string used by backend API/CLI/pipelines.
CIVITAS_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
# Optional dedicated database for destructive backend integration tests.
# Keep this separate from the app database used by the API/CLI.
# CIVITAS_TEST_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app_test

# Root directory for Bronze raw-source archives.
CIVITAS_BRONZE_ROOT=data/bronze

# Optional GIAS source overrides for deterministic local/CI runs.
# Set one of these to a local path or URL when direct site automation is unavailable.
# CIVITAS_GIAS_SOURCE_CSV=C:\path\to\edubasealldata.csv
# CIVITAS_GIAS_SOURCE_ZIP=C:\path\to\extract.zip

# Demographics source strategy (Phase 4 source stabilization).
# release_files is the only supported mode.
CIVITAS_DEMOGRAPHICS_SOURCE_MODE=release_files
# Publication slugs used for school-level underlying data discovery.
CIVITAS_DEMOGRAPHICS_SPC_PUBLICATION_SLUG=school-pupils-and-their-characteristics
CIVITAS_DEMOGRAPHICS_SEN_PUBLICATION_SLUG=special-educational-needs-in-england
# Comma-separated release slugs used to discover file ids (newest lookback window is selected).
CIVITAS_DEMOGRAPHICS_RELEASE_SLUGS=2019-20,2020-21,2021-22,2022-23,2023-24,2024-25
# Default lookback window used by release-files ingestion.
CIVITAS_DEMOGRAPHICS_LOOKBACK_YEARS=6
# Strict mode fails the run when any configured source/release cannot be discovered.
CIVITAS_DEMOGRAPHICS_SOURCE_STRICT_MODE=true

# DfE school performance source controls (KS2 + KS4 data-sets).
CIVITAS_DFE_PERFORMANCE_KS2_DATASET_ID=019afee4-e5d0-72f9-9a8f-d7a1a56eac1d
CIVITAS_DFE_PERFORMANCE_KS4_DATASET_ID=19e39901-a96c-be76-b9c2-6af54ae076d2
# Lookback years retained during staging/promotion.
CIVITAS_DFE_PERFORMANCE_LOOKBACK_YEARS=3
# DfE statistics API supports a maximum page size of 10000.
CIVITAS_DFE_PERFORMANCE_PAGE_SIZE=10000

# Optional ONS IMD source controls for Phase 2C.
# Local file or HTTP URL override for File 7 CSV.
# CIVITAS_IMD_SOURCE_CSV=C:\path\to\File_7_IoD2025.csv
# Release selector for default source URL when override is not set.
CIVITAS_IMD_RELEASE=iod2025

# Optional Police crime context source controls for Phase 2D.
# Explicit archive URL override (local path or HTTP URL).
# CIVITAS_POLICE_CRIME_SOURCE_ARCHIVE_URL=https://data.police.uk/data/archive/2026-01.zip
# Source mode: archive (default) or api (explicit unsupported for bulk pipeline runs).
CIVITAS_POLICE_CRIME_SOURCE_MODE=archive
# Aggregation radius used for school-local crime context counts.
CIVITAS_POLICE_CRIME_RADIUS_METERS=1609.344

# Optional Ofsted latest source override for deterministic local/CI runs.
# CIVITAS_OFSTED_LATEST_SOURCE_CSV=C:\path\to\latest_inspections.csv

# Optional Ofsted timeline source controls for Phase 2.
# Landing-page index URL override.
# CIVITAS_OFSTED_TIMELINE_SOURCE_INDEX_URL=https://www.gov.uk/government/statistical-data-sets/monthly-management-information-ofsteds-school-inspections-outcomes
# Rolling academic-year window for auto-selected timeline assets.
# Default is 10 years; set to 5 for lighter local hydration.
CIVITAS_OFSTED_TIMELINE_YEARS=10
# Explicit comma-separated asset override (local paths or URLs) for emergency pinning only.
# CIVITAS_OFSTED_TIMELINE_SOURCE_ASSETS=C:\path\to\all_inspections_2024.csv,C:\path\to\all_inspections_2025.csv
# Include 2015-2019 baseline asset when resolving from landing page.
CIVITAS_OFSTED_TIMELINE_INCLUDE_HISTORICAL_BASELINE=true

# Pipeline quality and resilience controls (H1 + H6).
CIVITAS_PIPELINE_MAX_REJECT_RATIO_GIAS=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_DFE_CHARACTERISTICS=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_DFE_PERFORMANCE=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_OFSTED_LATEST=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_OFSTED_TIMELINE=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_ONS_IMD=1.0
CIVITAS_PIPELINE_MAX_REJECT_RATIO_POLICE_CRIME_CONTEXT=1.0
CIVITAS_PIPELINE_HTTP_TIMEOUT_SECONDS=60
CIVITAS_PIPELINE_MAX_RETRIES=2
CIVITAS_PIPELINE_RETRY_BACKOFF_SECONDS=0.5
CIVITAS_PIPELINE_STAGE_CHUNK_SIZE=1000
CIVITAS_PIPELINE_PROMOTE_CHUNK_SIZE=1000
CIVITAS_PIPELINE_MAX_CONCURRENT_SOURCES=1
CIVITAS_PIPELINE_RESUME_ENABLED=true

# External HTTP client defaults (used by Phase 0+ integrations).
CIVITAS_HTTP_TIMEOUT_SECONDS=10
CIVITAS_HTTP_MAX_RETRIES=2
CIVITAS_HTTP_RETRY_BACKOFF_SECONDS=0.5

# Postcode search API configuration.
CIVITAS_POSTCODES_IO_BASE_URL=https://api.postcodes.io
CIVITAS_POSTCODE_CACHE_TTL_DAYS=30
# Backend school profile response cache (seconds).
# Set TTL to 0 to disable caching.
CIVITAS_SCHOOL_PROFILE_CACHE_TTL_SECONDS=300
# Poll interval for DB-backed cache invalidation token refresh.
CIVITAS_SCHOOL_PROFILE_CACHE_INVALIDATION_POLL_SECONDS=2

# Data-quality observability SLO controls (H5).
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_GIAS=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_DFE_CHARACTERISTICS=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_DFE_PERFORMANCE=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_OFSTED_LATEST=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_OFSTED_TIMELINE=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_ONS_IMD=720
CIVITAS_DATA_QUALITY_FRESHNESS_SLA_HOURS_POLICE_CRIME_CONTEXT=720
CIVITAS_DATA_QUALITY_COVERAGE_DRIFT_THRESHOLD=0.05
CIVITAS_DATA_QUALITY_MAX_CONSECUTIVE_HARD_FAILURES=2
CIVITAS_DATA_QUALITY_SPARSE_TREND_RATIO_THRESHOLD=0.7
