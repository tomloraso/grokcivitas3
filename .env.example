# Civitas runtime configuration (local development baseline)

# PostgreSQL connection string used by backend API/CLI/pipelines.
CIVITAS_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# Root directory for Bronze raw-source archives.
CIVITAS_BRONZE_ROOT=data/bronze

# Optional GIAS source overrides for deterministic local/CI runs.
# Set one of these to a local path or URL when direct site automation is unavailable.
# CIVITAS_GIAS_SOURCE_CSV=C:\path\to\edubasealldata.csv
# CIVITAS_GIAS_SOURCE_ZIP=C:\path\to\extract.zip

# Optional DfE characteristics source override for deterministic local/CI runs.
# CIVITAS_DFE_CHARACTERISTICS_SOURCE_CSV=C:\path\to\school_characteristics.csv
# Defaults to the validated Phase 1 dataset id from api.education.gov.uk.
CIVITAS_DFE_CHARACTERISTICS_DATASET_ID=019afee4-ba17-73cb-85e0-f88c101bb734

# Optional Ofsted latest source override for deterministic local/CI runs.
# CIVITAS_OFSTED_LATEST_SOURCE_CSV=C:\path\to\latest_inspections.csv

# Optional Ofsted timeline source controls for Phase 2.
# Landing-page index URL override.
# CIVITAS_OFSTED_TIMELINE_SOURCE_INDEX_URL=https://www.gov.uk/government/statistical-data-sets/monthly-management-information-ofsteds-school-inspections-outcomes
# Explicit comma-separated asset override (local paths or URLs).
# CIVITAS_OFSTED_TIMELINE_SOURCE_ASSETS=C:\path\to\all_inspections_ytd.csv,C:\path\to\all_inspections_historical_2015_2019.csv
# Include 2015-2019 baseline asset when resolving from landing page.
CIVITAS_OFSTED_TIMELINE_INCLUDE_HISTORICAL_BASELINE=true

# External HTTP client defaults (used by Phase 0+ integrations).
CIVITAS_HTTP_TIMEOUT_SECONDS=10
CIVITAS_HTTP_MAX_RETRIES=2
CIVITAS_HTTP_RETRY_BACKOFF_SECONDS=0.5

# Postcode search API configuration.
CIVITAS_POSTCODES_IO_BASE_URL=https://api.postcodes.io
CIVITAS_POSTCODE_CACHE_TTL_DAYS=30
