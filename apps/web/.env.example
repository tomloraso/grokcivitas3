# Public-facing site identity. These can remain as placeholders until launch,
# but production launch should set real values before indexing or billing.
VITE_SITE_NAME=BRAND
VITE_SITE_SHORT_NAME=BRAND
VITE_SITE_OPERATOR_NAME=Civitas
VITE_SITE_SUPPORT_EMAIL=hello@example.invalid
VITE_SITE_PRIVACY_EMAIL=privacy@example.invalid
VITE_SITE_DESCRIPTION=Independent school research for England. Explore official data on demographics, trends, Ofsted, and local context.

# Canonical public origin used for canonical URLs, sitemap generation, and structured data.
# Leave unset until the production domain is confirmed. When unset, sitemap generation stays
# non-indexable and canonical tags are omitted.
# VITE_PUBLIC_URL=

# Optional map tile provider override.
# Supported values:
# - cartodb-dark-matter (default)
# - cartodb-dark-nolabels
VITE_MAP_TILE_PROVIDER=cartodb-dark-matter

# Optional Stadia Maps API key for the dark fallback provider.
# Leave unset to use the no-label Carto fallback.
# VITE_STADIA_MAPS_API_KEY=
