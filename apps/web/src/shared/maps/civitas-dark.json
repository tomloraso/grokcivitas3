{
  "version": 8,
  "name": "Civitas Dark",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#0c1222" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["!=", ["get", "brunnel"], "tunnel"]
      ],
      "paint": { "fill-antialias": true, "fill-color": "#243447" }
    },
    {
      "id": "landcover_ice_shelf",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "subclass"], "ice_shelf"]
      ],
      "paint": { "fill-color": "#182030", "fill-opacity": 0.5 }
    },
    {
      "id": "landcover_glacier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "subclass"], "glacier"]
      ],
      "paint": {
        "fill-color": "#182030",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.7, 8, 0.3]
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 12,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "residential"]
      ],
      "paint": { "fill-color": "rgba(255, 255, 255, 0.02)" }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 10,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "wood"]
      ],
      "paint": {
        "fill-color": "rgba(255, 255, 255, 0.02)",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 10, 1, 14, 0.6]
      }
    },
    {
      "id": "landuse_park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "park"]
      ],
      "paint": { "fill-color": "rgba(255, 255, 255, 0.025)" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
      "paint": {
        "line-color": "#243447",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 14, 2]
      }
    },
    {
      "id": "water_name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 500,
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-rotation-alignment": "map",
        "text-size": 11,
        "text-letter-spacing": 0.14,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.25)",
        "text-halo-color": "rgba(36, 52, 71, 0.8)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "filter": ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
      "paint": { "fill-antialias": true, "fill-color": "rgba(255, 255, 255, 0.04)" }
    },
    {
      "id": "aeroway-taxiway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "minzoom": 12,
      "filter": ["match", ["get", "class"], ["taxiway"], true, false],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.06)",
        "line-width": ["interpolate", ["exponential", 1.55], ["zoom"], 13, 1, 20, 12]
      }
    },
    {
      "id": "aeroway-area",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "minzoom": 12,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["match", ["get", "class"], ["runway", "taxiway"], true, false]
      ],
      "paint": { "fill-color": "rgba(255, 255, 255, 0.04)" }
    },
    {
      "id": "aeroway-runway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "minzoom": 11,
      "filter": [
        "all",
        ["match", ["get", "class"], ["runway"], true, false],
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.08)",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 11, 2, 17, 30]
      }
    },
    {
      "id": "road_area_pier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "pier"]
      ],
      "paint": { "fill-antialias": true, "fill-color": "rgba(255, 255, 255, 0.04)" }
    },
    {
      "id": "road_pier",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["match", ["get", "class"], ["pier"], true, false]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.06)",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 15, 1, 17, 4]
      }
    },
    {
      "id": "highway_path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 15,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["==", ["get", "class"], "path"]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.05)",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 15, 0.5, 20, 3]
      }
    },
    {
      "id": "highway_minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["match", ["get", "class"], ["minor", "service", "track"], true, false]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.07)",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 13, 0.4, 16, 1.5, 20, 8]
      }
    },
    {
      "id": "highway_major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["match", ["get", "class"], ["primary", "secondary", "tertiary", "trunk"], true, false]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.12)",
        "line-width": ["interpolate", ["exponential", 1.3], ["zoom"], 8, 0.3, 12, 1.2, 16, 3.5, 20, 12]
      }
    },
    {
      "id": "highway_motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 5,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["==", ["get", "class"], "motorway"]
      ],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.16)",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 5, 0.4, 8, 0.8, 14, 2.5, 20, 10]
      }
    },
    {
      "id": "railway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 11,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["==", ["get", "class"], "rail"],
        ["!", ["has", "service"]]
      ],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.10)",
        "line-dasharray": [4, 3],
        "line-width": ["interpolate", ["exponential", 1.3], ["zoom"], 11, 0.5, 16, 1.5, 20, 3]
      }
    },
    {
      "id": "railway_transit",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 14,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["==", ["get", "class"], "transit"],
        ["match", ["get", "brunnel"], ["tunnel"], false, true]
      ],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.07)",
        "line-dasharray": [3, 3],
        "line-width": 1
      }
    },
    {
      "id": "highway_name_other",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 15,
      "filter": [
        "all",
        ["!=", ["get", "class"], "motorway"],
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false]
      ],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-max-angle": 30,
        "text-pitch-alignment": "viewport",
        "text-rotation-alignment": "map",
        "text-size": 9,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.06,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.35)",
        "text-halo-color": "rgba(12, 18, 34, 0.92)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0
      }
    },
    {
      "id": "highway_name_motorway",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["==", ["get", "class"], "motorway"]
      ],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-field": ["to-string", ["get", "ref"]],
        "text-font": ["Noto Sans Regular"],
        "text-pitch-alignment": "viewport",
        "text-rotation-alignment": "viewport",
        "text-size": 9,
        "text-letter-spacing": 0.04,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.40)",
        "text-halo-color": "rgba(12, 18, 34, 0.90)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0
      }
    },
    {
      "id": "boundary_state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", ["get", "admin_level"], 4],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.08)",
        "line-dasharray": [3, 2],
        "line-width": ["interpolate", ["exponential", 1.1], ["zoom"], 3, 0.3, 12, 1]
      }
    },
    {
      "id": "boundary_country_z0-4",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "maxzoom": 5,
      "filter": [
        "all",
        ["==", ["get", "admin_level"], 2],
        ["!", ["has", "claimed_by"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.12)",
        "line-width": ["interpolate", ["exponential", 1.1], ["zoom"], 0, 0.5, 5, 1.5]
      }
    },
    {
      "id": "boundary_country_z5-",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "minzoom": 5,
      "filter": ["==", ["get", "admin_level"], 2],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "rgba(255, 255, 255, 0.10)",
        "line-width": ["interpolate", ["exponential", 1.1], ["zoom"], 5, 0.5, 12, 1.5]
      }
    },
    {
      "id": "place_other",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 14,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["match", ["get", "class"], ["hamlet", "isolated_dwelling", "neighbourhood"], true, false]
      ],
      "layout": {
        "text-anchor": "center",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "center",
        "text-offset": [0.5, 0],
        "text-size": 9,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.04,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.30)",
        "text-halo-color": "rgba(12, 18, 34, 0.88)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 15,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "suburb"]
      ],
      "layout": {
        "text-anchor": "center",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "center",
        "text-offset": [0.5, 0],
        "text-size": 10,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.06,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.38)",
        "text-halo-color": "rgba(12, 18, 34, 0.90)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 14,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "village"]
      ],
      "layout": {
        "text-anchor": "center",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "center",
        "text-offset": [0.5, 0.2],
        "text-size": 10,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.06,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.42)",
        "text-halo-color": "rgba(12, 18, 34, 0.90)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 15,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "town"]
      ],
      "layout": {
        "text-anchor": ["step", ["zoom"], "left", 8, "center"],
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "left",
        "text-offset": [0.5, 0.2],
        "text-size": 11,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.06,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.52)",
        "text-halo-color": "rgba(12, 18, 34, 0.92)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 14,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "city"],
        [">", ["get", "rank"], 3]
      ],
      "layout": {
        "text-anchor": ["step", ["zoom"], "left", 8, "center"],
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "left",
        "text-offset": [0.5, 0.2],
        "text-size": 12,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.62)",
        "text-halo-color": "rgba(12, 18, 34, 0.92)",
        "text-halo-width": 1.4,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_city_large",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 12,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["<=", ["get", "rank"], 3],
        ["==", ["get", "class"], "city"]
      ],
      "layout": {
        "text-anchor": ["step", ["zoom"], "left", 8, "center"],
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-justify": "left",
        "text-offset": [0.5, 0.2],
        "text-size": 14,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.10,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.78)",
        "text-halo-color": "rgba(12, 18, 34, 0.94)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_state",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 12,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "state"]
      ],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 10,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "text-allow-overlap": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.55)",
        "text-halo-color": "rgba(12, 18, 34, 0.92)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_country_other",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "country"],
        ["!", ["has", "iso_a2"]]
      ],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 0, 9, 1, 11],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "rgba(255, 255, 255, 0.72)",
        "text-halo-color": "rgba(12, 18, 34, 0.94)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0
      }
    },
    {
      "id": "place_country_minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPoint", "Point"], true, false],
        ["==", ["get", "class"], "country"],
        [">=", ["get", "rank"], 2],
